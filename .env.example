# === MindMetricAI — Environment Variables ===

# Gemini API ключ (получить на https://aistudio.google.com/apikey)
VITE_API_KEY=your_gemini_api_key_here

# Режим разработки: true = mock auth, false = реальный FastAPI backend
VITE_MOCK_AUTH=true

# URL бэкенда (только когда VITE_MOCK_AUTH=false)
VITE_API_URL=http://localhost:8000
