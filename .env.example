# === MindMetricAI — Frontend Environment Variables ===

# Gemini API ключ (https://aistudio.google.com/apikey)
VITE_API_KEY=your_gemini_api_key_here

# false = реальный бэкенд, true = mock режим для разработки
VITE_MOCK_AUTH=false

# URL задеплоенного бэкенда на Railway
VITE_API_URL=https://your-backend.railway.app
